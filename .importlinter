# vim: ft=ini
[importlinter]
root_packages =
    agency
include_external_packages = True

# --- Cross-layer architecture ---
# Lower layers must not import higher layers.
# domain < io < features < entrypoints (composition roots)

[importlinter:contract:layers]
name = Layered architecture
type = layers
layers =
    agency.entrypoints
    agency.features
    agency.io
    agency.domain

# --- Features may only use io.observability ---
# Features receive backends via AppContext. They may use observability
# (a cross-cutting concern) but must never import adapters, bootstrap,
# transports, or any other io subpackage.

[importlinter:contract:features-io-boundary]
name = Features may no import io/ modules other than those in io.observability
type = forbidden
source_modules =
    agency.features
forbidden_modules =
    agency.io
ignore_imports =
    agency.features.** -> agency.io.observability.**

# --- io/ internal layering ---
# bootstrap -> adapters -> transports (lower must not import higher).

[importlinter:contract:io-internal-layers]
name = io/ internal layering (bootstrap -> adapters -> transports)
type = layers
layers =
    agency.io.bootstrap
    agency.io.adapters
    agency.io.transports

# --- io/errors independence ---
# io/errors.py may be imported by any io subpackage but depends on
# none of them (only domain).

[importlinter:contract:io-errors-independence]
name = io/errors does not depend on io/ subpackages
type = forbidden
source_modules =
    agency.io.errors
forbidden_modules =
    agency.io.adapters
    agency.io.bootstrap
    agency.io.transports
    agency.io.observability

# --- Observability independence ---
# Observability may be imported by any io subpackage but depends on
# none of them.

[importlinter:contract:observability-independence]
name = Observability does not depend on other io/ subpackages
type = forbidden
source_modules =
    agency.io.observability
forbidden_modules =
    agency.io.adapters
    agency.io.bootstrap
    agency.io.transports
    agency.io.errors

# --- domain/ internal rules ---
# models and errors are leaves; ports depend on models only;
# loop depends on models and ports; nothing in domain imports context.

[importlinter:contract:models-are-leaves]
name = Models are domain leaves
type = forbidden
source_modules =
    agency.domain.models
forbidden_modules =
    agency.domain.ports
    agency.domain.config
    agency.domain.context
    agency.domain.errors
    agency.domain.loop

[importlinter:contract:errors-are-leaves]
name = Errors are domain leaves
type = forbidden
source_modules =
    agency.domain.errors
forbidden_modules =
    agency.domain.ports
    agency.domain.models
    agency.domain.config
    agency.domain.context
    agency.domain.loop

[importlinter:contract:ports-depend-on-models-only]
name = Ports depend only on models
type = forbidden
source_modules =
    agency.domain.ports
forbidden_modules =
    agency.domain.config
    agency.domain.context
    agency.domain.errors
    agency.domain.loop

[importlinter:contract:loop-depends-on-models-and-ports]
name = Loop depends only on domain models, ports, and errors
type = forbidden
source_modules =
    agency.domain.loop
forbidden_modules =
    agency.domain.config
    agency.domain.context

# --- stdlib logging banned outside observability ---
# All logging must go through the shared logger in io.observability.logging.
# Only that module may import stdlib logging directly.

[importlinter:contract:no-direct-stdlib-logging]
name = Only io.observability.logging may import stdlib logging
type = forbidden
source_modules =
    agency
forbidden_modules =
    logging
ignore_imports =
    agency.io.observability.logging -> logging

[importlinter:contract:context-is-terminal]
name = Nothing in domain imports context
type = forbidden
source_modules =
    agency.domain.models
    agency.domain.ports
    agency.domain.config
    agency.domain.errors
    agency.domain.loop
forbidden_modules =
    agency.domain.context
